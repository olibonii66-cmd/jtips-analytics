const FOOTYSTATS_API_KEY = 'example';
const FOOTYSTATS_REMOTE_URL = 'https://api.football-data-api.com';
const FOOTYSTATS_PROXY_URL = './api/footystats';
const FALLBACK_LEAGUE_ID = 1625; // EPL 2018/2019 liberada para testes com key=example
const DEFAULT_SEASON_ID = 2012; // usado por endpoints que exigem season_id na documentação
const APP_TIMEZONE = 'America/Sao_Paulo';

const state = {
  matches: [],
  teams: [],
  players: [],
  marketChart: null,
  diagnostics: [],
};

const $ = (selector) => document.querySelector(selector);
const $$ = (selector) => [...document.querySelectorAll(selector)];

const endpoints = {
  todaysMatches: (date) => `/todays-matches?date=${date}&timezone=${encodeURIComponent(APP_TIMEZONE)}`,
  leagueMatches: (leagueId = FALLBACK_LEAGUE_ID) => `/league-matches?league_id=${leagueId}&max_per_page=500`,
  leagueTeams: (leagueId = FALLBACK_LEAGUE_ID) => `/league-teams?league_id=${leagueId}&include=stats`,
  leagueTables: (seasonId = DEFAULT_SEASON_ID) => `/league-tables?season_id=${seasonId}&include=stats`,
  leaguePlayers: (leagueId = FALLBACK_LEAGUE_ID) => `/league-players?league_id=${leagueId}&include=stats`,
  match: (matchId) => `/match?match_id=${matchId}`,
};

function getBaseUrlCandidates() {
  const isLocalFile = window.location.protocol === 'file:';
  const isVercelOrServer = window.location.protocol.startsWith('http');
  if (isLocalFile) return [FOOTYSTATS_REMOTE_URL];
  // No Vercel tentamos o proxy primeiro. Em Live Server, o proxy falha e caímos no remoto.
  return isVercelOrServer ? [FOOTYSTATS_PROXY_URL, FOOTYSTATS_REMOTE_URL] : [FOOTYSTATS_REMOTE_URL];
}

function appendDiagnostic(message, type = 'info') {
  const line = `[${new Date().toLocaleTimeString('pt-BR')}] ${message}`;
  state.diagnostics.unshift({ line, type });
  state.diagnostics = state.diagnostics.slice(0, 6);
  const box = $('#apiDiagnostics');
  if (!box) return;
  box.innerHTML = state.diagnostics
    .map((item) => `<div class="diag-line ${item.type}">${item.line}</div>`)
    .join('');
}

function buildUrl(base, path) {
  const glue = path.includes('?') ? '&' : '?';
  return `${base}${path}${glue}key=${encodeURIComponent(FOOTYSTATS_API_KEY)}`;
}

async function footyFetch(path, { raw = false } = {}) {
  const bases = getBaseUrlCandidates();
  const errors = [];

  for (const base of bases) {
    const url = buildUrl(base, path);
    try {
      appendDiagnostic(`Chamando ${path} via ${base.includes('api/footystats') ? 'proxy Vercel' : 'API direta'}...`);
      const response = await fetch(url, { headers: { Accept: 'application/json' } });
      const text = await response.text();
      let payload;
      try {
        payload = JSON.parse(text);
      } catch {
        throw new Error(`Resposta não JSON: ${text.slice(0, 120) || response.statusText}`);
      }

      if (!response.ok) throw new Error(`HTTP ${response.status}: ${payload?.message || payload?.error || response.statusText}`);
      if (payload?.success === false || payload?.error) throw new Error(payload.message || payload.error || 'A API recusou a requisição.');

      const normalized = raw ? payload : normalizeApiArray(payload);
      const total = Array.isArray(normalized) ? normalized.length : 1;
      appendDiagnostic(`${path} retornou ${total} registro(s).`, total ? 'ok' : 'warn');
      console.info('[FootyStats]', path, { total, payload });
      return normalized;
    } catch (error) {
      errors.push(`${base}: ${error.message}`);
      appendDiagnostic(`${path} falhou via ${base.includes('api/footystats') ? 'proxy' : 'direto'}: ${error.message}`, 'warn');
    }
  }

  throw new Error(errors.join(' | '));
}

async function footyFetchFirst(paths) {
  const errors = [];
  for (const path of paths) {
    try {
      const data = await footyFetch(path);
      if (data.length) return data;
      errors.push(`${path}: retornou 0 registros`);
    } catch (error) {
      errors.push(`${path}: ${error.message}`);
    }
  }
  console.warn('[FootyStats] Nenhum endpoint retornou registros', errors);
  appendDiagnostic(`Nenhum endpoint retornou dados úteis. Veja o console para detalhes.`, 'warn');
  return [];
}

function normalizeApiArray(payload) {
  if (Array.isArray(payload)) return payload;
  if (!payload || typeof payload !== 'object') return [];

  const commonContainers = [
    payload.data,
    payload.matches,
    payload.fixtures,
    payload.result,
    payload.results,
    payload.players,
    payload.teams,
    payload.table,
    payload.league_table,
    payload.all_matches,
  ];

  for (const item of commonContainers) {
    if (Array.isArray(item)) return item;
  }

  if (payload.data && typeof payload.data === 'object') {
    const nested = normalizeApiArray(payload.data);
    if (nested.length) return nested;
  }

  // Último recurso: encontra o maior array dentro do payload.
  let bestArray = [];
  const visit = (value) => {
    if (!value || typeof value !== 'object') return;
    if (Array.isArray(value)) {
      if (value.length > bestArray.length) bestArray = value;
      return;
    }
    Object.values(value).forEach(visit);
  };
  visit(payload);
  if (bestArray.length) return bestArray;

  return [];
}

function todayISO() {
  return new Intl.DateTimeFormat('en-CA', { timeZone: APP_TIMEZONE }).format(new Date());
}

function unixToTime(unix) {
  if (!unix || Number(unix) < 0) return '--:--';
  return new Intl.DateTimeFormat('pt-BR', { hour: '2-digit', minute: '2-digit', timeZone: APP_TIMEZONE }).format(new Date(Number(unix) * 1000));
}

function percent(value) {
  const number = Number(value);
  if (!Number.isFinite(number) || number < 0) return '--';
  return `${Math.round(number)}%`;
}

function numberOrDash(value, digits = 2) {
  const number = Number(value);
  if (!Number.isFinite(number) || number < 0) return '--';
  return number.toFixed(digits).replace('.', ',');
}

function getFirst(obj, keys, fallback = undefined) {
  for (const key of keys) {
    if (obj?.[key] !== undefined && obj?.[key] !== null && obj?.[key] !== '') return obj[key];
  }
  return fallback;
}

function teamName(match, side) {
  const keys = side === 'home'
    ? ['home_name', 'homeName', 'team_a_name', 'team_a', 'home_team_name', 'teamA', 'team_a_name_pretty']
    : ['away_name', 'awayName', 'team_b_name', 'team_b', 'away_team_name', 'teamB', 'team_b_name_pretty'];
  return getFirst(match, keys, side === 'home' ? `Time ${match.homeID || match.team_a_id || 'A'}` : `Time ${match.awayID || match.team_b_id || 'B'}`);
}

function leagueName(match) {
  return getFirst(match, ['competition_name', 'league', 'season', 'league_name', 'country'], `Liga ${match.competition_id || match.league_id || '--'}`);
}

function matchScore(match) {
  const home = getFirst(match, ['homeGoalCount', 'home_goals', 'team_a_goals', 'home_score'], '-');
  const away = getFirst(match, ['awayGoalCount', 'away_goals', 'team_b_goals', 'away_score'], '-');
  return `${home ?? '-'} x ${away ?? '-'}`;
}

function statusLabel(status) {
  const normalized = String(status || '').toLowerCase();
  if (normalized.includes('complete') || normalized === 'finished' || normalized === 'ft') return 'Finalizado';
  if (normalized.includes('live') || normalized.includes('progress')) return 'Ao vivo';
  if (normalized.includes('suspend')) return 'Suspenso';
  if (normalized.includes('cancel')) return 'Cancelado';
  return 'Agendado';
}

function impliedProbability(odd) {
  const value = Number(odd);
  if (!Number.isFinite(value) || value <= 1) return null;
  return 100 / value;
}

function isValueBet(probability, odd) {
  const implied = impliedProbability(odd);
  const model = Number(probability);
  return Number.isFinite(model) && implied && model > implied + 5;
}

function setSkeleton(selector, quantity = 3) {
  const element = $(selector);
  if (!element) return;
  element.innerHTML = Array.from({ length: quantity }, () => '<div class="skeleton"></div>').join('');
}

function showError(selector, message) {
  const element = $(selector);
  if (!element) return;
  element.innerHTML = `<div class="error-box"><strong>Não foi possível carregar.</strong><br>${message}</div>`;
}

async function loadDashboard() {
  setApiStatus('carregando');
  appendDiagnostic('Iniciando carregamento do dashboard...');
  ['#featuredMatches', '#teamStats', '#playerStats', '#oddsGrid', '#tipsList'].forEach((selector) => setSkeleton(selector));
  $('#matchesTable').innerHTML = `<tr><td colspan="7"><div class="skeleton"></div></td></tr>`;

  const date = $('#matchDate').value || todayISO();
  try {
    const [todayMatches, leagueMatches, teams, leagueTableTeams, players] = await Promise.all([
      footyFetchFirst([endpoints.todaysMatches(date)]),
      footyFetchFirst([endpoints.leagueMatches()]),
      footyFetchFirst([endpoints.leagueTeams()]),
      footyFetchFirst([endpoints.leagueTables()]),
      footyFetchFirst([endpoints.leaguePlayers()]),
    ]);

    const matchesData = todayMatches.length ? todayMatches : leagueMatches;
    const teamsData = teams.length ? teams : leagueTableTeams;

    state.matches = matchesData.slice(0, 120);
    state.teams = teamsData.slice(0, 12);
    state.players = players.slice(0, 30);

    renderAll();
    setApiStatus(state.matches.length ? 'ok' : 'vazio');
    if (!state.matches.length) {
      appendDiagnostic('A API respondeu, mas nenhum jogo foi retornado. Confirme key/league_id.', 'warn');
    }
  } catch (error) {
    setApiStatus('erro');
    appendDiagnostic(`Erro geral: ${error.message}`, 'error');
    ['#featuredMatches', '#teamStats', '#playerStats', '#oddsGrid', '#tipsList'].forEach((selector) => showError(selector, error.message));
    $('#matchesTable').innerHTML = `<tr><td colspan="7">Falha ao carregar dados: ${error.message}</td></tr>`;
  }
}

function setApiStatus(status) {
  const apiStatus = $('#apiStatus');
  apiStatus.className = 'status-pill';
  if (status === 'ok') { apiStatus.textContent = 'API online'; apiStatus.classList.add('ok'); }
  else if (status === 'erro') { apiStatus.textContent = 'API com falha'; apiStatus.classList.add('error'); }
  else if (status === 'vazio') { apiStatus.textContent = 'API sem jogos'; apiStatus.classList.add('error'); }
  else { apiStatus.textContent = 'Carregando'; }
}

function renderAll() {
  renderKpis();
  renderFeaturedMatches();
  renderMatchesTable();
  renderTeams();
  renderPlayers();
  renderOdds();
  renderTips();
  renderMarketChart();
}

function renderKpis() {
  const matches = state.matches;
  const overValues = matches.map((m) => Number(getFirst(m, ['o25_potential', 'o25_potential_pre_match', 'o25', 'over25_potential']))).filter(Number.isFinite);
  const bttsValues = matches.map((m) => Number(getFirst(m, ['btts_potential', 'btts_potential_pre_match']))).filter(Number.isFinite);
  const values = matches.filter((m) => isValueBet(getFirst(m, ['o25_potential', 'o25_potential_pre_match']), getFirst(m, ['odds_ft_over25', 'odds_over_25']))).length;
  $('#kpiMatches').textContent = matches.length;
  $('#kpiOver25').textContent = overValues.length ? percent(avg(overValues)) : '--';
  $('#kpiBtts').textContent = bttsValues.length ? percent(avg(bttsValues)) : '--';
  $('#kpiValue').textContent = values;
}

function avg(list) { return list.reduce((sum, value) => sum + value, 0) / list.length; }

function renderFeaturedMatches() {
  const featured = [...state.matches]
    .sort((a, b) => Number(getFirst(b, ['o25_potential', 'o25_potential_pre_match'], 0)) - Number(getFirst(a, ['o25_potential', 'o25_potential_pre_match'], 0)))
    .slice(0, 5);

  $('#featuredMatches').innerHTML = featured.length ? featured.map((match) => `
    <article class="match-card">
      <div class="match-teams"><strong>${teamName(match, 'home')}</strong><span>${unixToTime(getFirst(match, ['date_unix', 'kickoff_unix']))}</span><strong>${teamName(match, 'away')}</strong></div>
      <div class="scoreline"><span>${leagueName(match)}</span><strong>${matchScore(match)}</strong><span>${statusLabel(match.status)}</span></div>
      <div class="odds-row"><span>Over 2.5: ${percent(getFirst(match, ['o25_potential', 'o25_potential_pre_match']))}</span><span>BTTS: ${percent(getFirst(match, ['btts_potential', 'btts_potential_pre_match']))}</span><span class="value">${valueLabel(match)}</span></div>
    </article>`).join('') : emptyState('Nenhuma partida encontrada. Com key=example, o fallback deveria usar a EPL 2018/2019; veja o diagnóstico acima.');
}

function renderMatchesTable() {
  const leagueText = $('#leagueFilter').value.toLowerCase().trim();
  const status = $('#statusFilter').value;
  const rows = state.matches.filter((match) => {
    const leagueOk = !leagueText || leagueName(match).toLowerCase().includes(leagueText);
    const matchStatus = String(match.status || '').toLowerCase();
    const statusOk = status === 'all' || matchStatus.includes(status) || (status === 'complete' && ['finished', 'ft'].includes(matchStatus));
    return leagueOk && statusOk;
  });

  $('#matchesTable').innerHTML = rows.length ? rows.map((match) => `
    <tr>
      <td>${unixToTime(getFirst(match, ['date_unix', 'kickoff_unix']))}</td>
      <td>${leagueName(match)}</td>
      <td>${teamName(match, 'home')}</td>
      <td><strong>${matchScore(match)}</strong></td>
      <td>${teamName(match, 'away')}</td>
      <td>${statusLabel(match.status)}</td>
      <td><span class="tag">O2.5 ${percent(getFirst(match, ['o25_potential', 'o25_potential_pre_match']))}</span> <span class="tag">BTTS ${percent(getFirst(match, ['btts_potential', 'btts_potential_pre_match']))}</span></td>
    </tr>`).join('') : `<tr><td colspan="7">Nenhum jogo bate com os filtros.</td></tr>`;
}

function renderTeams() {
  const teams = state.teams.slice(0, 6);
  $('#teamStats').innerHTML = teams.length ? teams.map((team) => `
    <article class="stat-card">
      <span>${team.country || team.cleanName || 'Equipe'}</span>
      <strong>${team.name || team.full_name || team.english_name || team.cleanName || `Time ${team.id}`}</strong>
      <p>PPG: ${numberOrDash(getFirst(team, ['seasonPPG_overall', 'points_per_game', 'ppg']))} · Vitórias: ${percent(getFirst(team, ['winPercentage_overall', 'win_percentage']))} · Gols: ${numberOrDash(getFirst(team, ['seasonGoals_overall', 'goals_scored', 'goalsFor']), 0)}</p>
      <p>BTTS: ${percent(getFirst(team, ['seasonBTTSPercentage_overall', 'btts_percentage']))} · Cartões: ${numberOrDash(getFirst(team, ['cardsTotal_overall', 'seasonCards_overall', 'cards_total']), 0)}</p>
    </article>`).join('') : emptyState('Sem estatísticas de times nesta chave/temporada.');
}

function renderPlayers() {
  const players = [...state.players]
    .sort((a, b) => Number(getFirst(b, ['goals_overall', 'goals'], 0)) - Number(getFirst(a, ['goals_overall', 'goals'], 0)))
    .slice(0, 8);
  $('#playerStats').innerHTML = players.length ? players.map((player, index) => `
    <div class="leader-row">
      <div><strong>#${index + 1} ${player.full_name || player.known_as || player.name || 'Jogador'}</strong><br><span class="muted">${player.position || '--'} · ${player.nationality || '--'}</span></div>
      <div><strong>${getFirst(player, ['goals_overall', 'goals'], 0)}</strong><br><span class="muted">gols</span></div>
    </div>`).join('') : emptyState('Sem estatísticas de jogadores nesta chave/temporada.');
}

function renderOdds() {
  const matches = state.matches.filter((match) => getFirst(match, ['odds_ft_1', 'odds_ft_home_team_win']) || getFirst(match, ['odds_ft_x', 'odds_ft_draw']) || getFirst(match, ['odds_ft_2', 'odds_ft_away_team_win'])).slice(0, 9);
  $('#oddsGrid').innerHTML = matches.length ? matches.map((match) => `
    <article class="odds-card">
      <strong>${teamName(match, 'home')} x ${teamName(match, 'away')}</strong>
      <p class="muted">${leagueName(match)}</p>
      <div class="odds-row"><span>1: ${numberOrDash(getFirst(match, ['odds_ft_1', 'odds_ft_home_team_win']))}</span><span>X: ${numberOrDash(getFirst(match, ['odds_ft_x', 'odds_ft_draw']))}</span><span>2: ${numberOrDash(getFirst(match, ['odds_ft_2', 'odds_ft_away_team_win']))}</span></div>
      <p class="${isValueBet(getFirst(match, ['o25_potential', 'o25_potential_pre_match']), getFirst(match, ['odds_ft_over25', 'odds_over_25'])) ? 'value' : 'no-value'}">${valueLabel(match)}</p>
    </article>`).join('') : emptyState('Nenhuma odd disponível no conjunto retornado.');
}

function renderTips() {
  const tips = state.matches
    .filter((match) => Number(getFirst(match, ['o25_potential', 'o25_potential_pre_match'], 0)) > 55 || Number(getFirst(match, ['btts_potential', 'btts_potential_pre_match'], 0)) > 55)
    .slice(0, 6);
  $('#tipsList').innerHTML = tips.length ? tips.map((match) => {
    const over = Number(getFirst(match, ['o25_potential', 'o25_potential_pre_match'], 0));
    const btts = Number(getFirst(match, ['btts_potential', 'btts_potential_pre_match'], 0));
    const market = over >= btts ? 'Over 2.5 gols' : 'Ambas marcam';
    const confidence = Math.min(5, Math.max(1, Math.round(Math.max(over, btts) / 20)));
    return `<article class="tip-card">
      <strong>${teamName(match, 'home')} x ${teamName(match, 'away')}</strong>
      <span class="tag">Mercado sugerido: ${market}</span>
      <p>Modelo indica boa aderência estatística ao mercado, considerando potencial pré-jogo e odds disponíveis.</p>
      <span class="stars">${'★'.repeat(confidence)}${'☆'.repeat(5 - confidence)}</span>
    </article>`;
  }).join('') : emptyState('Ainda não há tips fortes para este filtro.');
}

function renderMarketChart() {
  const ctx = $('#marketsChart');
  if (!ctx || !window.Chart) return;
  const data = {
    over25: state.matches.filter((m) => Number(getFirst(m, ['o25_potential', 'o25_potential_pre_match'], 0)) >= 55).length,
    btts: state.matches.filter((m) => Number(getFirst(m, ['btts_potential', 'btts_potential_pre_match'], 0)) >= 55).length,
    cards: state.matches.filter((m) => Number(getFirst(m, ['cards_potential', 'cards_potential_pre_match'], 0)) >= 4).length,
  };
  if (state.marketChart) state.marketChart.destroy();
  state.marketChart = new Chart(ctx, {
    type: 'doughnut',
    data: { labels: ['Over 2.5', 'BTTS', 'Cartões'], datasets: [{ data: [data.over25, data.btts, data.cards] }] },
    options: { plugins: { legend: { labels: { color: getComputedStyle(document.documentElement).getPropertyValue('--text') } } } }
  });
}

function valueLabel(match) {
  return isValueBet(getFirst(match, ['o25_potential', 'o25_potential_pre_match']), getFirst(match, ['odds_ft_over25', 'odds_over_25'])) ? 'Value bet em Over 2.5' : 'Sem value claro';
}

function emptyState(message) { return `<div class="error-box">${message}</div>`; }

async function handleH2H(event) {
  event.preventDefault();
  const matchId = $('#matchIdInput').value.trim();
  if (!matchId) return showError('#h2hResults', 'Informe um ID de partida válido.');
  setSkeleton('#h2hResults', 2);
  try {
    const [match] = await footyFetch(endpoints.match(matchId));
    const h2h = match?.h2h || match?.head_to_head || match?.head2head;
    if (!h2h) return showError('#h2hResults', 'A partida foi encontrada, mas não retornou dados H2H nesta chave.');
    $('#h2hResults').innerHTML = `
      <article class="h2h-card">
        <strong>${teamName(match, 'home')} x ${teamName(match, 'away')}</strong>
        <p>Vitórias mandante: ${percent(getFirst(h2h, ['team_a_win_percent', 'home_win_percent']))} · Empates: ${percent(h2h.draw_percent)} · Vitórias visitante: ${percent(getFirst(h2h, ['team_b_win_percent', 'away_win_percent']))}</p>
        <p>Over 2.5 H2H: ${percent(getFirst(h2h, ['over25_percent', 'o25_percent']))} · BTTS H2H: ${percent(h2h.btts_percent)}</p>
      </article>`;
  } catch (error) {
    showError('#h2hResults', error.message);
  }
}

function setupInteractions() {
  $('#matchDate').value = todayISO();
  $('#refreshBtn').addEventListener('click', loadDashboard);
  $('#leagueFilter').addEventListener('input', renderMatchesTable);
  $('#statusFilter').addEventListener('change', renderMatchesTable);
  $('#h2hForm').addEventListener('submit', handleH2H);
  $('#menuToggle').addEventListener('click', () => $('#sidebar').classList.toggle('open'));
  $$('.nav-link').forEach((link) => link.addEventListener('click', () => $('#sidebar').classList.remove('open')));
  $('#themeToggle').addEventListener('click', toggleTheme);
}

function toggleTheme() {
  const current = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
  document.documentElement.dataset.theme = current === 'light' ? 'light' : '';
  localStorage.setItem('theme', current);
  $('#themeToggle').innerHTML = current === 'light' ? '<i class="fa-solid fa-sun"></i><span>Light</span>' : '<i class="fa-solid fa-moon"></i><span>Dark</span>';
  renderMarketChart();
}

function hydrateTheme() {
  const saved = localStorage.getItem('theme');
  if (saved === 'light') {
    document.documentElement.dataset.theme = 'light';
    $('#themeToggle').innerHTML = '<i class="fa-solid fa-sun"></i><span>Light</span>';
  }
}

try {
  setupInteractions();
  hydrateTheme();
  loadDashboard();
} catch (error) {
  console.error('[FootyEdge] Erro de inicialização:', error);
  document.body.insertAdjacentHTML('afterbegin', `<div style="padding:12px;margin:12px;border:1px solid #ef4444;border-radius:12px;background:#3f1111;color:#fff">Erro ao inicializar o app: ${error.message}</div>`);
}
